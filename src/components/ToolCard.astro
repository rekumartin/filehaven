---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  screenshot?: string;
}
const { icon, title, description, href, screenshot } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-lg border border-stone-200 bg-white hover:border-stone-400 hover:shadow-sm transition-all duration-200 overflow-hidden"
>
  {screenshot && (
    <div class="h-40 overflow-hidden border-b border-stone-100 shrink-0">
      <img
        src={screenshot}
        alt=""
        class="w-full h-full object-cover object-top scale-100 group-hover:scale-[1.02] transition-transform duration-300"
        aria-hidden="true"
        loading="lazy"
      />
    </div>
  )}
  <div class="flex flex-col gap-3 p-5 flex-1">
    <div
      class="text-stone-500 group-hover:text-stone-800 transition-colors shrink-0"
      aria-hidden="true"
      set:html={icon}
    />
    <div class="flex-1">
      <h3 class="font-medium text-stone-900 mb-1.5 text-sm leading-snug">
        {title}
      </h3>
      <p class="text-sm text-stone-500 leading-relaxed">{description}</p>
    </div>
    <div class="flex items-center gap-1 text-xs text-stone-400 group-hover:text-stone-700 transition-colors mt-auto">
      <span>Open tool</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </div>
  </div>
</a>
