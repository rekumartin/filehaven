---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
}
const { icon, title, description, href } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col gap-3 rounded-2xl border border-gray-200 bg-white p-6 hover:border-blue-300 hover:shadow-md transition-all duration-200"
>
  <div class="flex items-center gap-3">
    <span class="text-2xl leading-none" aria-hidden="true">{icon}</span>
    <h3 class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">
      {title}
    </h3>
  </div>
  <p class="text-sm text-gray-500 leading-relaxed flex-1">{description}</p>
  <span
    class="mt-1 text-sm font-medium text-blue-600 group-hover:underline underline-offset-2"
    aria-hidden="true"
  >
    Open tool →
  </span>
</a>
