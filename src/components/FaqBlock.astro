---
export interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  heading?: string;
}

const { items, heading = 'Frequently asked questions' } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};
---

<section class="mt-14" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="text-xl font-semibold text-gray-900 mb-5">{heading}</h2>
  <div class="divide-y divide-gray-100 border border-gray-200 rounded-xl overflow-hidden">
    {
      items.map(({ question, answer }) => (
        <details class="group bg-white">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-medium text-gray-900 hover:bg-gray-50 transition-colors select-none">
            {question}
            <svg
              class="shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180 text-gray-400"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </summary>
          <p class="px-5 pb-4 pt-1 text-gray-600 text-sm leading-relaxed">{answer}</p>
        </details>
      ))
    }
  </div>
</section>

<!-- schema.org FAQPage JSON-LD for rich search results -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
