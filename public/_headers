# Cloudflare Pages response headers
# https://developers.cloudflare.com/pages/configuration/headers/

# ── Hashed static assets — cache forever ───────────────────────────────────
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# ── All routes — security headers ──────────────────────────────────────────
/*
  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Forbid framing (belt-and-suspenders with CSP frame-ancestors)
  X-Frame-Options: DENY

  # Never send Referer to third-party origins — files in transit are private
  Referrer-Policy: no-referrer

  # Force HTTPS for 1 year; include subdomains; eligible for preload list
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Deny every sensitive browser API we don't use
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), interest-cohort=(), display-capture=(), clipboard-read=()

  # ── Content-Security-Policy ────────────────────────────────────────────────
  #
  # Third-party origins in use:
  #   script-src  static.cloudflare.com   — Cloudflare Web Analytics beacon
  #   connect-src cloudflareinsights.com  — where the beacon posts page-view data
  #
  # 'wasm-unsafe-eval' is required for heic2any (libheif WASM embedded in JS
  # bundle) and for pdfjs-dist WASM decoders (jbig2, openjpeg). No other
  # eval-based code is present or permitted.
  #
  # All npm libraries (heic2any, pdfjs-dist, pdf-lib, piexifjs) are bundled
  # locally by Vite and served from 'self'. No CDN scripts.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' static.cloudflare.com; style-src 'self'; img-src 'self' blob: data:; font-src 'self'; connect-src 'self' cloudflareinsights.com; media-src 'none'; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; worker-src 'self' blob:; upgrade-insecure-requests
